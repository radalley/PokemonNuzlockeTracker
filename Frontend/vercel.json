{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://lockley-uat.onrender.com/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/sprites/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
