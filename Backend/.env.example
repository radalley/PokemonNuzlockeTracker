# Copy this to .env and fill in your values
DATABASE_URL=postgresql://username:password@localhost:5432/lockley

# Flask secret key - change this to a random string in production
LOCKLEY_SECRET_KEY=lockley-dev-secret-change-me

# Set to 1 in production (HTTPS only)
LOCKLEY_SECURE_COOKIES=0

# Supabase project URL (used for JWT JWKS verification)
SUPABASE_URL=https://your-project-ref.supabase.co

# Optional: comma-separated CORS allowlist. Leave empty for localhost defaults.
# Example: LOCKLEY_CORS_ORIGINS=https://lockleytracker.com,https://www.lockleytracker.com
LOCKLEY_CORS_ORIGINS=
